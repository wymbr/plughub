{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "CommonJS",
    "lib":                        ["ES2022"],
    "types":                      ["node"],
    "strict":                     true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess":   true,
    "outDir":                     "dist",
    "declaration":                true,
    "declarationMap":             true,
    "sourceMap":                  true,
    "moduleResolution":           "node",
    "esModuleInterop":            true,
    "skipLibCheck":               true,
    "incremental":                true
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}

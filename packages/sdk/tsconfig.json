{
  "compilerOptions": {
    "target":                    "ES2020",
    "module":                    "CommonJS",
    "lib":                       ["ES2020"],
    "types":                     ["node"],
    "strict":                    true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess":  true,
    "outDir":                    "dist",
    "declaration":               true,
    "declarationMap":            true,
    "sourceMap":                 true,
    "esModuleInterop":           true,
    "skipLibCheck":              true,
    "paths": {
      "@plughub/schemas": ["../schemas/src/index.ts"]
    }
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}

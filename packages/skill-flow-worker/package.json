{
  "name": "@plughub/skill-flow-worker",
  "version": "1.0.0",
  "description": "PlugHub Platform — Skill Flow worker: consumes workflow.events, runs SkillFlowEngine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build":     "tsc",
    "start":     "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev":       "tsx src/index.ts"
  },
  "dependencies": {
    "@plughub/schemas":           "file:../schemas",
    "@plughub/skill-flow-engine": "file:../skill-flow-engine",
    "kafkajs":                    "^2.2.4",
    "ioredis":                    "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript":  "^5.4.0",
    "tsx":         "^4.0.0"
  },
  "homepage": "https://plughub.io"
}

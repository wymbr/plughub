{
  "compilerOptions": {
    "target":                     "ES2020",
    "module":                     "CommonJS",
    "lib":                        ["ES2020"],
    "strict":                     true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess":   true,
    "outDir":                     "dist",
    "declaration":                true,
    "sourceMap":                  true,
    "esModuleInterop":            true,
    "skipLibCheck":               true,
    "incremental":                true
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}
